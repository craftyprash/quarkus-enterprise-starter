{
  "openapi": "3.0.3",
  "info": {
    "title": "LMS API",
    "version": "0.1.0",
    "description": "Loan Management System integration mock for Microcks"
  },
  "paths": {
    "/api/v1/disbursements": {
      "post": {
        "operationId": "recordDisbursement",
        "summary": "Record a disbursement in LMS",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "drawdownId": { "type": "integer" },
                  "amount": { "type": "number" },
                  "bankReference": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disbursement recorded",
            "content": {
              "application/json": {
                "examples": {
                  "success": {
                    "value": {
                      "status": "RECORDED"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
